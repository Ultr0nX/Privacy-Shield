# macOS
.DS_Store
.AppleDouble
.LSOverride

# Environment Files (NEVER commit secrets)
.env
.env.*
!.env.example

# =============================
# Node / React (ui/)
# =============================
node_modules/
dist/
build/
npm-debug.log*
yarn-error.log*

# =============================
# Rust (relayer/)
# =============================
target/
**/*.rs.bk
# Note: Cargo.lock is intentionally kept for binary crates (reproducible builds)

# =============================
# Foundry (contracts/)
# =============================
out/
cache/
# Generated lockfiles
foundry.lock
**/foundry.lock

# Foundry dependency libraries (managed as git submodules)
contracts/privacy-shield/lib/

# =============================
# ZK Circuit Large Files
# =============================
# Powers of Tau ceremony files (very large, download separately)
*.ptau

# Intermediate proving keys (not final)
circuits/privacy_0000.zkey
circuits/privacy_js/privacy.wasm

# Witness files (intermediate computation, never commit)
*.wtns

# Large JSON dumps of proving keys
circuits/circuit_final.zkey.json

# =============================
# Backup / Temp Files
# =============================
*_backup.*
*_old.*
*.bak
*.tmp
# Files with spaces in name (usually accidental duplicates)
*\ *.rs
*\ *.js
*\ *.sol

# =============================
# ZK Generated Symbol Files
# =============================
*.sym

# =============================
# Claude Code
# =============================
.claude/

# =============================
# React Build Output
# =============================
ui/build/

# =============================
# IDE / Editor
# =============================
.vscode/
.idea/
*.swp
*.swo

