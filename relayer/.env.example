# RPC URL for the blockchain network
# Local (Anvil/Hardhat): http://127.0.0.1:8545
# Sepolia: https://ethereum-sepolia-rpc.publicnode.com
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Private key for the relayer wallet (must have Sepolia ETH to pay gas)
# NEVER commit real private keys to git!
PRIVATE_KEY=0xYOUR_SEPOLIA_PRIVATE_KEY

# Deployed PrivacyShield contract address (Sepolia example)
# Update this after your latest deployment
CONTRACT_ADDRESS=0xcd91023700b1261450aa90042e9d62426beab45b
